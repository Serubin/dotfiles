# Paths chezmoi must never manage (matched against target paths under $HOME).
#
# IMPORTANT: do NOT list external targets (.zsh/zinit, .zsh/gitstatus,
# .tmux/plugins) here. .chezmoiignore removes entries from the target state,
# including .chezmoiexternal entries — ignoring them would silently prevent the
# plugin-manager clones.

# zsh runtime / compiled caches
.zsh/cache
*.zwc
.zcompdump*

# nvim runtime: shell history + lazy.nvim lock/state (unpinned, like today)
.config/.histfile
.config/nvim/lazy-lock.json
.config/nvim/lazyvim.json
.config/nvim/lazy

# Claude Code: only the curated config (settings.json, CLAUDE.md, skills/,
# plugins/{known_marketplaces,blocklist}.json) is managed. Guard the
# machine-local override, secrets, and the cloned marketplace repos.
.claude/settings.local.json
.claude/.credentials.json
.claude/plugins/marketplaces

# Repo docs kept next to the config they document, but NOT deployed to $HOME.
# (.zsh/README.md would otherwise be sourced by .zshrc's `~/.zsh/*` loop.)
.zsh/README.md
.config/nvim/README.md

# ----- machine-class gating (see README "Machine targeting" + feature matrix) -----
# Gate by OS (.chezmoi.os), environment (.environment), or class (.class). Patterns
# match TARGET paths. NOTE: never glob a path that would swallow a .chezmoiexternal
# target (.zsh/zinit, .zsh/gitstatus, .tmux/plugins/tpm) — that suppresses its clone.

# yabai + skhd are macOS window-manager configs — keep on ANY mac, skip elsewhere.
{{ if ne .chezmoi.os "darwin" }}
.config/yabai
.config/skhd
{{ end }}

# Class-specific example scripts (replace with your own). A custom class (e.g.
# homelab) matches neither, so both are ignored — add your own class gate for it.
{{ if ne .class "work-mac" }}
.local/bin/example-work-mac
{{ end }}
{{ if ne .class "work-devbox" }}
.local/bin/example-work-devbox
{{ end }}

# tmux -CC (iTerm2 control-mode) devbox helpers: the periodic-save cron target
# and the stale-client-clearing connect helper. work-devbox only — the mac side
# of this workflow is the sleepwatcher feature below.
{{ if ne .class "work-devbox" }}
.local/bin/tmux-periodic-save.sh
.local/bin/tmux-devel.sh
{{ end }}

# sleepwatcher sleep/wake feature (Coder iTerm2/tmux + fwd hygiene): work-mac only.
{{ if ne .class "work-mac" }}
.config/sleepwatcher
Library/LaunchAgents/net.serubin.sleepwatcher.plist
{{ end }}
