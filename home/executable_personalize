#!/usr/bin/env bash
# Work-devbox startup bootstrap. Managed by chezmoi (source: home/executable_personalize).
#
# Runs at startup to reconverge state that does NOT survive a host restart: the
# dotfiles themselves (via chezmoi), the sshd keepalive drop-in in /etc, and the
# tmux-save cron. Persistent $HOME files are managed by chezmoi directly and are
# NOT regenerated here (previously this script inlined the tmux helper scripts).
# Deliberately not `set -e`: a single failing step must not skip the rest.

#pip install pynvim

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# --- Dotfiles: install chezmoi if missing + apply, by running this repo's
# install.sh from the persisted local source checkout (no network / branch
# dependency, and it works before the migration lands on the default branch).
# install.sh also runs the base-package chezmoiscript and deploys the helper
# scripts this bootstrap calls below.
DOTFILES_SRC="${DOTFILES_SRC:-$HOME/.dotfiles}"
if [ -x "$DOTFILES_SRC/install.sh" ]; then
    "$DOTFILES_SRC/install.sh" --env work --class work-devbox
else
    echo "[personalize] chezmoi source not found at $DOTFILES_SRC;" \
         "onboard first by running this repo's install.sh." >&2
fi

# --- Work-devbox packages. Nothing outside /home/coder survives a host restart,
# so every package not baked into the base image is (re)installed here each run
# (chezmoi's run_once can't help: its "done" state persists but the packages
# don't). spr = stacked-PR workflow; claude-code = Claude Code CLI.
brew install \
    ejoffe/tap/spr \
    claude-code@latest \
    mosh \
    inotify-tools \
    googleworkspace-cli \
    jj \
    glow

# --- Reset VSCode settings for the lwcode workspace (background; work-specific).
nohup /home/coder/lwcode/reset-vscode-settings.sh > /tmp/startup-vscode-settings.log 2>&1 &

# --- SSH keepalive drop-in in /etc (root-owned, wiped on restart -> re-applied
# here, not by chezmoi). Generation lives in its own chezmoi-managed script.
"$HOME/.local/bin/apply-sshd-keepalive.sh"

# --- Periodic tmux-resurrect save cron (every 5 min). The crontab does not survive
# a host restart, so it is (re)installed here rather than at chezmoi apply. The
# script itself is chezmoi-managed (~/.local/bin/tmux-periodic-save.sh); this only
# schedules it. Idempotent: de-duped by the marker comment, other entries preserved.
if command -v crontab >/dev/null 2>&1; then
    line="*/5 * * * * $HOME/.local/bin/tmux-periodic-save.sh >/dev/null 2>&1 # tmux-periodic-save"
    ( crontab -l 2>/dev/null | grep -vF '# tmux-periodic-save'; echo "$line" ) | crontab -
fi

# --- Coder keep-alive. Holds the workspace autostop deadline out until 6pm ET on
# weekdays so a long meeting/lunch (no activity) can't reclaim the box mid-day. The
# helper (re)provisions a stable coder binary under ~/.local/state (the PATH one
# lives in a per-SSH-session /tmp dir) and installs its own */15 cron -- both are
# wiped on a host restart, so like the tmux cron above they are re-established here.
# It reuses the ambient `coder login` session; if that expires it warns via a
# ~/.zsh startup banner. Script is chezmoi-managed (~/.local/bin/coder-keepalive.sh).
if [ -x "$HOME/.local/bin/coder-keepalive.sh" ]; then
    "$HOME/.local/bin/coder-keepalive.sh" install || true
fi
