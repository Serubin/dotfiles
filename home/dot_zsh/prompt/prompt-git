# Git prompt powered by gitstatus (romkatv/gitstatus)
# Replaces the vendored __git_ps1 with a persistent background daemon,
# eliminating per-prompt git subprocess overhead.
#
# Provides git_stat() for use by prompt-theme.
# Requires: gitstatus (brew install romkatv/gitstatus/gitstatus, or clone romkatv/gitstatus)

_gitstatus_plugin=""
for _p in \
    "${GITSTATUS_DIR}/gitstatus.plugin.zsh" \
    "/opt/homebrew/opt/gitstatus/gitstatus.plugin.zsh" \
    "/usr/local/opt/gitstatus/gitstatus.plugin.zsh" \
    "${HOME}/.zsh/gitstatus/gitstatus.plugin.zsh"
do
    [[ -r "$_p" ]] && _gitstatus_plugin="$_p" && break
done
unset _p

if [[ -z "$_gitstatus_plugin" ]]; then
    print -P "%F{yellow}Warning: gitstatus not found. Install with: brew install romkatv/gitstatus/gitstatus%f" >&2
    function git_stat() { }
    unset _gitstatus_plugin
    return 0
fi

source "$_gitstatus_plugin"
unset _gitstatus_plugin

gitstatus_stop PROMPT 2>/dev/null
gitstatus_start -s 1 -u 1 -c 1 -d 1 PROMPT

function git_stat() {
    gitstatus_query PROMPT || return
    [[ "$VCS_STATUS_RESULT" == "ok-sync" ]] || return

    # Resolve the git directory (needed for branch name during rebase)
    local g="$VCS_STATUS_WORKDIR/.git"
    if [[ -f "$g" ]]; then
        local gitdir_ref
        read -r gitdir_ref < "$g"
        g="${gitdir_ref#gitdir: }"
    fi

    # Action state (rebase, merge, etc.)
    # VCS_STATUS_ACTION is a composite string: "rebase-i 2/3" (action + step/total)
    # Split on first space to get action type and optional step/total.
    local action=""
    if [[ -n "$VCS_STATUS_ACTION" ]]; then
        local action_type="${VCS_STATUS_ACTION%% *}"
        local action_extra="${VCS_STATUS_ACTION#* }"
        [[ "$action_extra" == "$VCS_STATUS_ACTION" ]] && action_extra=""

        case "$action_type" in
            rebase-i)   action="|REBASE-i" ;;
            rebase-m)   action="|REBASE-m" ;;
            rebase)     action="|REBASE" ;;
            am)         action="|AM" ;;
            am/rebase)  action="|AM/REBASE" ;;
            merge)      action="|MERGING" ;;
            cherry)     action="|CHERRY-PICKING" ;;
            cherry-seq) action="|CHERRY-PICKING" ;;
            revert)     action="|REVERTING" ;;
            revert-seq) action="|REVERTING" ;;
            bisect)     action="|BISECTING" ;;
        esac
        [[ -n "$action_extra" ]] && action="$action $action_extra"
    fi

    # Branch name: use local branch, read from rebase state files during
    # rebase (git is in detached HEAD), or fall back to tag / short SHA
    local branch
    if [[ -n "$VCS_STATUS_LOCAL_BRANCH" ]]; then
        branch="$VCS_STATUS_LOCAL_BRANCH"
    elif [[ -r "$g/rebase-merge/head-name" ]]; then
        read -r branch < "$g/rebase-merge/head-name"
        branch="${branch#refs/heads/}"
    elif [[ -r "$g/rebase-apply/head-name" ]]; then
        read -r branch < "$g/rebase-apply/head-name"
        branch="${branch#refs/heads/}"
    elif [[ -n "$VCS_STATUS_TAG" ]]; then
        branch="($VCS_STATUS_TAG)"
    else
        branch="(${VCS_STATUS_COMMIT[1,7]}...)"
    fi

    local dirty=0
    (( VCS_STATUS_NUM_STAGED + VCS_STATUS_NUM_UNSTAGED + VCS_STATUS_NUM_UNTRACKED + VCS_STATUS_NUM_CONFLICTED > 0 )) && dirty=1

    if (( dirty )); then
        echo "${git_color_dirty}${git_dirty_prefix}${branch}${action}${git_dirty_suffix}${Color_Off}"
    else
        echo "${git_color_clean}${git_clean_prefix}${branch}${action}${git_clean_suffix}${Color_Off}"
    fi
}
