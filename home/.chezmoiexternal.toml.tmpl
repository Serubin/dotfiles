# Plugin managers, cloned and kept up to date by chezmoi (replaces the old
# per-OS manual `git clone` setup scripts).
#
# Note: these only install the *managers*. zinit auto-installs its plugins on
# the first interactive shell (see dot_zsh/executable_02-zinit); tpm still needs
# `prefix + I` or `~/.tmux/plugins/tpm/bin/install_plugins` to fetch tmux plugins.

[".zsh/zinit"]
    type = "git-repo"
    url = "https://github.com/zdharma-continuum/zinit.git"
    refreshPeriod = "168h"

[".tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"

{{- if eq .chezmoi.os "linux" }}

# macOS gets gitstatus via Homebrew (prompt-git prefers the brew path); on Linux
# we clone it. A shallow clone is enough — gitstatus ships a prebuilt daemon
# fetcher, no history needed.
[".zsh/gitstatus"]
    type = "git-repo"
    url = "https://github.com/romkatv/gitstatus.git"
    refreshPeriod = "168h"
    [".zsh/gitstatus".clone]
        args = ["--depth=1"]
{{- end }}
